          "descriptionEn": "List all environments and their paths"
        }
      ]
    },
    {
      "id": "maintenance",
      "name": "维护清理",
      "nameEn": "Maintenance",
      "commands": [
        {
          "id": "cmd-3",
          "command": "conda clean --all",
          "description": "清理所有缓存（包、索引、锁文件）",
          "descriptionEn": "Clean all cache (packages, index, lock files)"
        },
        {
          "id": "cmd-4",
          "command": "conda doctor",
          "description": "诊断 conda 环境问题",
          "descriptionEn": "Diagnose conda environment issues"
        }
      ]
    },
    {
      "id": "update",
      "name": "更新升级",
      "nameEn": "Update",
      "commands": [
        {
          "id": "cmd-5",
          "command": "conda update conda",
          "description": "更新 conda 本身",
          "descriptionEn": "Update conda itself"
